# KOPRINDO FOX n8n environment template
# Copy file ini menjadi .env atau masukkan variabelnya ke environment instance n8n Anda.

# General
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/

# Default intake metadata
DEFAULT_SOURCE_TYPE=sell_out
DEFAULT_SOURCE_PARTY=manual_admin
DEFAULT_CHANNEL=all
DEFAULT_PERIOD_MONTH=4
DEFAULT_PERIOD_YEAR=2026

# FOX operational thresholds
KOPRINDO_STOCKOUT_THRESHOLD=120
KOPRINDO_OVERSTOCK_THRESHOLD=2800
KOPRINDO_RECON_WARNING_THRESHOLD=0.10
KOPRINDO_RECON_HIGH_THRESHOLD=0.20
KOPRINDO_RECON_CRITICAL_THRESHOLD=0.35
KOPRINDO_PAYMENT_HIGH_DAYS=10
KOPRINDO_PAYMENT_CRITICAL_DAYS=30

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=koprindo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Production WhatsApp Cloud API
META_WABA_API_VERSION=v22.0
META_WABA_PHONE_NUMBER_ID=
META_WABA_ACCESS_TOKEN=
OPS_WA_RECIPIENT_HIGH=
OPS_WA_RECIPIENT_CRITICAL=

# Staging WhatsApp Cloud API
STAGING_META_WABA_API_VERSION=v22.0
STAGING_META_WABA_PHONE_NUMBER_ID=
STAGING_META_WABA_ACCESS_TOKEN=
STAGING_OPS_WA_RECIPIENT_HIGH=
STAGING_OPS_WA_RECIPIENT_CRITICAL=

# Optional legacy / modular workflow variables
N8N_INTERNAL_WEBHOOK_BASE_URL=http://localhost:5678
KOPRINDO_WEBAPP_BASE_URL=http://localhost:3000
KOPRINDO_WEBAPP_API_KEY=
GOOGLE_DRIVE_SHARED_FOLDER_ID=
SFTP_INBOUND_PATH=
OPENAI_API_KEY=
OPENAI_MODEL_PARSER=gpt-4.1-mini
OPENAI_MODEL_SUMMARY=gpt-4.1-mini
