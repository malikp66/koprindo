        "path": "escalation-alert",
        "options": {}
      },
      "id": "1be68b57-a36c-48c0-bc66-3d7f02cdff0c",
      "name": "Push Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
