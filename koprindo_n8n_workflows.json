      ],
      "notesInFlow": true,
      "notes": "Workflow 4: Notification Alerts",
      "webhookId": "9740dc33-fd4a-40a1-8d26-b8cb79be6a8d"
    },
    {
      "parameters": {
        "rules": {
          "values": [
